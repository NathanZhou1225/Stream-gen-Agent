# 复制为 .env 并填入真实值；勿提交 .env。
# 嵌在 OpenClaw 整仓时：可与上级 .env 合并（见 scripts/verify_env.py）；verify 也会读取当前进程环境（宿主可注入 OPENCLAW_*）。

# =============================================================================
# 主对话 / Agent 默认模型
# =============================================================================
# 由当前 OpenClaw / WorkBuddy 宿主配置即可，本文件不强制 Ark/DeepSeek/Dashscope。
# 可选覆盖（供子进程回退）：
# ARK_API_KEY=
# ARK_MODEL_ID=ark-code-latest
# ARK_BASE_URL=

# =============================================================================
# 云端 Newsbox（唯一常规数据路径 · 只 clone 本仓）
# =============================================================================
# 采集 / Tushare / RSSHub / ingest clean 在运维机 finance-ingest-cloud；本仓只拉 API + 本地 Router。
# 外网业务机：http://<云端公网IP>:8080 ；云端本机调试：http://127.0.0.1:8080
FINANCE_CLOUD_API_BASE_URL=http://127.0.0.1:8080
FINANCE_CLOUD_API_KEY=
FINANCE_CLOUD_API_TIMEOUT=90
# query_market_facts 整链约 90–120s；飞书 exec 须 timeout≥300，见 AGENTS.md

# =============================================================================
# Router（db_snapshot --pre-router-stdin 仍须本地 Router）— 默认开启
# =============================================================================
# 关闭：FINANCE_LLM_ROUTER_ENABLED=0
FINANCE_LLM_ROUTER_ENABLED=1
FINANCE_LLM_ROUTER_BASE_URL=
FINANCE_LLM_ROUTER_API_KEY=
FINANCE_LLM_ROUTER_MODEL=deepseek-v4-flash
# FINANCE_LLM_ROUTER_RETRY_EXTRA=1
# FINANCE_LLM_ROUTER_RETRY_SLEEP_SEC=0.4

# =============================================================================
# db_snapshot 展示（云路径对齐 legacy 四行：事件/影响/角度）
# =============================================================================
# FINANCE_DB_SNAPSHOT_DISPLAY_PER_SECTOR=5
# FINANCE_LLM_ROUTER_MENU_PER_SECTOR=12
# FINANCE_DB_SNAPSHOT_SHOW_DEEP_SECTION=0
# FINANCE_SECTOR_LLM_REWRITE_MAX_ITEMS=5

# =============================================================================
# Rewriter（板块润色）— 默认开启（可与 Router/Clean 共用密钥回退）
# =============================================================================
# 关闭：FINANCE_SECTOR_LLM_REWRITE_ENABLED=0
FINANCE_SECTOR_LLM_REWRITE_ENABLED=1
# FINANCE_SECTOR_LLM_BASE_URL=
# FINANCE_SECTOR_LLM_API_KEY=
# FINANCE_SECTOR_LLM_MODEL=

# =============================================================================
# 开稿 preflight（缓存优先 · 关热榜）
# =============================================================================
# 默认跳过 fetch_hot_rank，省 5–15s；恢复热榜：PREFLIGHT_SKIP_HOT_RANK=0
PREFLIGHT_SKIP_HOT_RANK=1
# 证据包不足时勿默认二次 ingest；仅运维显式 --allow-targeted-fetch

# =============================================================================
# 客户端快照预热 cron（见 scripts/setup_snapshot_warm_cron.sh）
# =============================================================================
# FINANCE_SNAPSHOT_WARM_LOG=cache/snapshot/warm.log
# FINANCE_SNAPSHOT_WARM_TIMEOUT_SEC=300

# =============================================================================
# 联网 legacy（显式 --live-fetch / preflight --source-mode legacy，需本机 RSS 等）
# =============================================================================
# FINANCE_RSSHUB_BASE_URL=http://127.0.0.1:1200
# STREAM_GEN_SKIP_P1_READINESS=0

# =============================================================================
# 选配（未配置仅 [OPTIONAL] 提示，不阻断安装）
# =============================================================================
FEISHU_APP_ID=
FEISHU_APP_SECRET=
TELEGRAM_BOT_TOKEN=
TAVILY_API_KEY=
# STREAM_GEN_MIN_CONTEXT_RESET_AFTER_FINALIZE=1
