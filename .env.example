# 复制为 .env 并填入真实值；勿提交 .env。
# 嵌在 OpenClaw 整仓时：可与上级 .env 合并（见 scripts/verify_env.py）；verify 也会读取当前进程环境（宿主可注入 OPENCLAW_*）。

# =============================================================================
# 主对话 / Agent 默认模型
# =============================================================================
# 由当前 OpenClaw / WorkBuddy 宿主配置即可，本文件不强制 Ark/DeepSeek/Dashscope。
# 可选覆盖（供子进程回退）：
# ARK_API_KEY=
# ARK_MODEL_ID=ark-code-latest
# ARK_BASE_URL=

# =============================================================================
# 云端 Newsbox（v0.3.0 默认 · 只 clone 本仓的推荐路径）
# =============================================================================
# 采集 / Tushare / RSSHub / ingest clean 在运维机 finance-ingest-cloud；本仓只拉 API + 本地 Router。
FINANCE_CLOUD_MODE=1
# 外网业务机：http://<云端公网IP>:8080 ；云端本机调试：http://127.0.0.1:8080
FINANCE_CLOUD_API_BASE_URL=http://127.0.0.1:8080
FINANCE_CLOUD_API_KEY=
FINANCE_CLOUD_API_TIMEOUT=60

# =============================================================================
# Router（db_snapshot / 云模式客户端仍须本地 Router）— 默认开启
# =============================================================================
# 关闭：FINANCE_LLM_ROUTER_ENABLED=0
FINANCE_LLM_ROUTER_ENABLED=1
FINANCE_LLM_ROUTER_BASE_URL=
FINANCE_LLM_ROUTER_API_KEY=
FINANCE_LLM_ROUTER_MODEL=deepseek-v4-flash

# =============================================================================
# Rewriter（板块润色）— 默认开启（可与 Router/Clean 共用密钥回退）
# =============================================================================
# 关闭：FINANCE_SECTOR_LLM_REWRITE_ENABLED=0
FINANCE_SECTOR_LLM_REWRITE_ENABLED=1
# FINANCE_SECTOR_LLM_BASE_URL=
# FINANCE_SECTOR_LLM_API_KEY=
# FINANCE_SECTOR_LLM_MODEL=

# =============================================================================
# Advanced：本地 ingest + SQLite（FINANCE_CLOUD_MODE=0 时 deploy_readiness 校验此项）
# =============================================================================
# FINANCE_CLOUD_MODE=0
# TUSHARE_TOKEN=
# FINANCE_RSSHUB_BASE_URL=
# FINANCE_INGEST_LLM_CLEAN_ENABLED=1
# FINANCE_INGEST_LLM_CLEAN_BASE_URL=
# FINANCE_INGEST_LLM_CLEAN_API_KEY=
# FINANCE_INGEST_LLM_CLEAN_MODEL=deepseek-v4-flash
# STREAM_GEN_SKIP_P1_READINESS=0

# =============================================================================
# 选配（未配置仅 [OPTIONAL] 提示，不阻断安装）
# =============================================================================
FEISHU_APP_ID=
FEISHU_APP_SECRET=
TELEGRAM_BOT_TOKEN=
TAVILY_API_KEY=
# STREAM_GEN_MIN_CONTEXT_RESET_AFTER_FINALIZE=1
