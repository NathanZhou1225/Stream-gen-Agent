{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$comment": "与 prompts/script-generation.md、scripts/script_renderer.py、draft_manager.py update --stage script_refining 对拍。Agent 提交的 payload 勿含 display_markdown。",
  "title": "streamy-content-gen script.json",
  "description": "逐字稿阶段 script.json 结构。落盘为 draft 目录下 script.json；合规扫描后由工具写回 compliance.*",
  "type": "object",
  "additionalProperties": true,
  "required": ["draft_id", "duration_sec", "segments", "production_appendix"],
  "properties": {
    "draft_id": {
      "type": "string",
      "description": "三位 Base36，与 meta.json 一致；与 `^[A-HJ-NP-Z0-9]{3}$`（I/O 排除）在运行上等价。",
      "minLength": 3,
      "maxLength": 3
    },
    "title": { "type": "string", "description": "稿件标题，与 outline 或 meta.topic 对齐" },
    "duration_sec": {
      "type": "integer",
      "minimum": 1,
      "description": "总时长（秒），与各 segment 时长之和差 ≤5s 为宜"
    },
    "structure_template": {
      "type": "string",
      "description": "与 outline 的 structure_template 对齐",
      "enum": ["standard", "reversal", "listicle", "story", "debate"]
    },
    "segments": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/segment" }
    },
    "cta": { "$ref": "#/definitions/cta" },
    "production_appendix": { "$ref": "#/definitions/production_appendix" },
    "production_style_adaptation": { "$ref": "#/definitions/production_style_adaptation" },
    "compliance": { "$ref": "#/definitions/compliance" },
    "source": { "$ref": "#/definitions/source" }
  },
  "definitions": {
    "segment": {
      "type": "object",
      "required": ["time", "role", "say"],
      "additionalProperties": true,
      "properties": {
        "time": {
          "type": "string",
          "description": "时间窗 M:SS–M:SS（如 0:00-0:04 或 1:15-1:27）",
          "pattern": "^\\d+:\\d{2}-\\d+:\\d{2}$"
        },
        "role": {
          "type": "string",
          "description": "script_renderer._fmt_role 有友好标签；可自由增加字符串，但建议用下列",
          "enum": [
            "hook",
            "argument_1",
            "argument_2",
            "argument_3",
            "argument",
            "turn",
            "scene",
            "conflict",
            "result",
            "action",
            "cta"
          ]
        },
        "say": { "type": "string", "description": "本段口播正文" },
        "claim_kind": {
          "type": "string",
          "enum": ["fact", "opinion", "mixed"],
          "description": "T6：区分事实陈述/观点判断/混合（hook/cta 可省略）"
        },
        "evidence_source_type": {
          "type": "string",
          "enum": ["market", "news_flash", "announcement", "hotlist", "inference", "user_judgement"],
          "description": "T6：事实或混合段的证据来源类型"
        },
        "evidence_source_ref": {
          "type": "string",
          "description": "T6：事实或混合段的来源引用（如 财联社14:56 / tushare:index_daily）"
        },
        "visual": {
          "type": "array",
          "items": { "type": "string" },
          "description": "如 贴纸:惊叹、配图:柱状图、特效:zoom-in、动作:手指屏幕"
        },
        "cta_hint": {
          "oneOf": [
            { "type": "string" },
            { "type": "null" }
          ],
          "description": "本段内 CTA 埋词；无则 null"
        }
      }
    },
    "cta": {
      "type": "object",
      "description": "全局 CTA；与 references/cta-patterns.md 合并枚举（业务话术可替换，类型名保留）",
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "add_wechat",
            "comment_reply",
            "follow_series",
            "join_group",
            "dm_keyword"
          ],
          "description": "join_group、dm_keyword 为 cta-patterns 侧命名；与 comment_reply、follow_series 可并存，勿新增类型除非同步 PRD"
        },
        "position": {
          "type": "string",
          "enum": ["opening", "middle", "ending", "triple"]
        },
        "phrasing": { "type": "string" }
      },
      "additionalProperties": true
    },
    "production_appendix": {
      "type": "object",
      "required": ["camera_shots", "stickers_effects", "visual_assets", "host_actions"],
      "additionalProperties": false,
      "properties": {
        "camera_shots": {
          "type": "array",
          "minItems": 3,
          "maxItems": 5,
          "items": { "type": "string" },
          "description": "镜头建议（3-5 条）"
        },
        "stickers_effects": {
          "type": "array",
          "minItems": 3,
          "maxItems": 5,
          "items": { "type": "string" },
          "description": "贴纸/特效建议（3-5 条）"
        },
        "visual_assets": {
          "type": "array",
          "minItems": 3,
          "maxItems": 5,
          "items": { "type": "string" },
          "description": "配图建议（3-5 条）"
        },
        "host_actions": {
          "type": "array",
          "minItems": 3,
          "maxItems": 5,
          "items": { "type": "string" },
          "description": "人物行为建议（3-5 条）"
        }
      }
    },
    "production_style_adaptation": {
      "type": "object",
      "required": ["ip_style_adaptation", "tone_style_adaptation", "visual_style_adaptation"],
      "additionalProperties": false,
      "properties": {
        "ip_style_adaptation": {
          "type": "string",
          "description": "T8：本稿如何贴合 IP 定位（方法论/结构/节奏）"
        },
        "tone_style_adaptation": {
          "type": "string",
          "description": "T8：本稿语气与表达风格如何落地（口头禅/句式/力度）"
        },
        "visual_style_adaptation": {
          "type": "string",
          "description": "T8：镜头/贴纸/配图如何贴合该风格"
        }
      }
    },
    "compliance": {
      "type": "object",
      "description": "初稿可 pending；update 后由 lite_compliance_scan 写回。draft_manager 异常时见 scan_failed 仅作提示非持久化主路径",
      "properties": {
        "status": {
          "type": "string",
          "enum": ["pending", "pass", "warn"]
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "term": { "type": "string" },
              "match_kind": { "type": "string" },
              "offset": { "type": "integer" },
              "context": { "type": "string" },
              "pattern": { "type": "string" },
              "segment_role": { "type": "string" },
              "at_time": { "type": "string" },
              "segment_index": { "type": "integer" }
            }
          }
        },
        "scanned_at": { "type": "string" },
        "scanner_version": { "type": "string" }
      },
      "additionalProperties": true
    },
    "source": {
      "type": "object",
      "properties": {
        "topic": { "type": "string" },
        "data_sources": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    }
  }
}
